---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<span class="brand">// WLKOM</span>
		<span class="copy">&copy; {today.getFullYear()}, Ariane Luc, Daniel Janson, Kealan Murphy Molas, Tom Rioult Denorme</span>
		<span class="school">SYS2 · EPITA</span>
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid var(--border);
		padding: 1.5em;
		background: var(--bg);
	}

	.footer-inner {
		max-width: 860px;
		margin: auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.5em;
		font-size: 0.8em;
		color: var(--muted);
	}

	.brand {
		font-family: 'Courier New', monospace;
		color: var(--accent);
		font-weight: bold;
	}

	@media (max-width: 600px) {
		.footer-inner { flex-direction: column; text-align: center; }
	}
</style>
