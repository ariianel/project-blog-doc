---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="brand">{SITE_TITLE}<span class="cursor">▋</span></a>
		<div class="links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/architecture">Architecture</HeaderLink>
			<HeaderLink href="/setup">Setup</HeaderLink>
			<HeaderLink href="/choices">Choices</HeaderLink>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		margin: 0;
		padding: 0 1em;
		background: rgba(13, 17, 23, 0.92);
		backdrop-filter: blur(8px);
		border-bottom: 1px solid var(--border);
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 56px;
		width: 860px;
		max-width: 100%;
		margin: 0 auto;
	}

	.brand {
		font-family: 'Courier New', monospace;
		font-size: 1.1em;
		font-weight: 700;
		color: var(--accent);
		text-decoration: none;
		letter-spacing: 2px;
	}

	.cursor {
		animation: blink 1s step-end infinite;
		color: var(--accent);
	}

	@keyframes blink {
		50% { opacity: 0; }
	}

	.links {
		display: flex;
		align-items: center;
		gap: 0.5em;
	}

	.gh-link {
		display: flex;
		align-items: center;
		color: var(--muted);
		padding: 0.4em;
		transition: color 0.15s;
	}

	.gh-link:hover {
		color: var(--accent);
		text-decoration: none;
	}

	@media (max-width: 480px) {
		.gh-link { display: none; }
	}
</style>
