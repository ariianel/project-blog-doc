---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="brand">{SITE_TITLE}<span class="cursor">▋</span></a>
		<div class="links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/architecture">Architecture</HeaderLink>
			<HeaderLink href="/setup">Setup</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<a href="https://github.com" target="_blank" class="gh-link">
				<svg viewBox="0 0 16 16" aria-hidden="true" width="20" height="20">
					<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
				</svg>
			</a>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		margin: 0;
		padding: 0 1em;
		background: rgba(13, 17, 23, 0.92);
		backdrop-filter: blur(8px);
		border-bottom: 1px solid var(--border);
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 56px;
		width: 860px;
		max-width: 100%;
		margin: 0 auto;
	}

	.brand {
		font-family: 'Courier New', monospace;
		font-size: 1.1em;
		font-weight: 700;
		color: var(--accent);
		text-decoration: none;
		letter-spacing: 2px;
	}

	.cursor {
		animation: blink 1s step-end infinite;
		color: var(--accent);
	}

	@keyframes blink {
		50% { opacity: 0; }
	}

	.links {
		display: flex;
		align-items: center;
		gap: 0.5em;
	}

	.gh-link {
		display: flex;
		align-items: center;
		color: var(--muted);
		padding: 0.4em;
		transition: color 0.15s;
	}

	.gh-link:hover {
		color: var(--accent);
		text-decoration: none;
	}

	@media (max-width: 480px) {
		.gh-link { display: none; }
	}
</style>
