---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead title="C2 Server — WLKOM" description="Technical documentation of the WLKOM C2 server." />
</head>
<body>
  <Header />
  <main>

    <div class="breadcrumb"><a href="/features">Features</a> / C2 Server</div>

    <div class="page-header">
      <div class="badge">Attacking program</div>
      <h1>// C2 Server</h1>
      <p class="subtitle">
        A Flask web application that acts as the command-and-control server —
        managing victim machines, dispatching commands, and handling file transfers.
      </p>
      <div class="tech-pills">
        <span class="pill">Python 3</span>
        <span class="pill">Flask</span>
        <span class="pill">SQLite</span>
        <span class="pill">Jinja2</span>
        <span class="pill">AJAX</span>
      </div>
    </div>

    <!-- 1. Overview -->
    <section class="section">
      <h2 class="section-title">01 — Overview</h2>
      <p class="section-desc">
        The C2 server is the attacker's control panel. It exposes two interfaces:
        a <strong>web dashboard</strong> for the operator, and a <strong>REST API</strong> for the rootkit.
        Both run on the same Flask process on port 5000.
      </p>

      <div class="two-cols">
        <div class="col-card">
          <h3>Web Dashboard</h3>
          <p>Password-protected interface for the operator. Shows all connected machines in real-time, lets you dispatch commands, upload/download files, and view results — all from a browser.</p>
        </div>
        <div class="col-card">
          <h3>Rootkit API</h3>
          <p>Unauthenticated HTTP/1.0 REST API consumed by the kernel module. Handles registration, action polling, result submission, and binary file transfer.</p>
        </div>
      </div>
    </section>

    <!-- 2. Database -->
    <section class="section">
      <h2 class="section-title">02 — Database schema</h2>
      <p class="section-desc">
        All state is persisted in a single SQLite file (<code>c2.db</code>), managed by <code>database.py</code>.
        Four tables cover the full lifecycle of a machine interaction.
      </p>

      <div class="db-schema">
        <div class="table-card">
          <div class="table-name">machines</div>
          <div class="table-desc">One row per registered rootkit instance.</div>
          <div class="cols">
            <div class="col pk">uuid <span>TEXT PK</span></div>
            <div class="col">ip <span>TEXT</span></div>
            <div class="col">registered_at <span>TEXT</span></div>
            <div class="col">last_seen <span>TEXT</span></div>
          </div>
        </div>
        <div class="table-card">
          <div class="table-name">actions</div>
          <div class="table-desc">Queue of commands waiting to be consumed by the rootkit.</div>
          <div class="cols">
            <div class="col pk">id <span>INT PK</span></div>
            <div class="col fk">machine_uuid <span>FK</span></div>
            <div class="col">command <span>TEXT</span></div>
            <div class="col">consumed <span>INT (0/1)</span></div>
            <div class="col">created_at <span>TEXT</span></div>
          </div>
        </div>
        <div class="table-card">
          <div class="table-name">results</div>
          <div class="table-desc">Command outputs posted back by the rootkit.</div>
          <div class="cols">
            <div class="col pk">id <span>INT PK</span></div>
            <div class="col fk">machine_uuid <span>FK</span></div>
            <div class="col">command <span>TEXT</span></div>
            <div class="col">exit_code <span>INT</span></div>
            <div class="col">stdout <span>TEXT</span></div>
            <div class="col">stderr <span>TEXT</span></div>
          </div>
        </div>
        <div class="table-card">
          <div class="table-name">transfers</div>
          <div class="table-desc">History of all file uploads and downloads.</div>
          <div class="cols">
            <div class="col pk">id <span>INT PK</span></div>
            <div class="col fk">machine_uuid <span>FK</span></div>
            <div class="col">direction <span>'upload' | 'download'</span></div>
            <div class="col">remote_path <span>TEXT</span></div>
            <div class="col">local_path <span>TEXT</span></div>
            <div class="col">size <span>INT (bytes)</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- 3. Routes -->
    <section class="section">
      <h2 class="section-title">03 — Routes</h2>

      <h3 class="sub-title">Frontend (operator)</h3>
      <div class="route-table-wrap">
        <table class="route-table">
          <thead><tr><th>Method</th><th>Route</th><th>Description</th></tr></thead>
          <tbody>
            <tr>
              <td><span class="method get">GET</span></td>
              <td><code>/login</code></td>
              <td>Login page</td>
            </tr>
            <tr>
              <td><span class="method post">POST</span></td>
              <td><code>/login</code></td>
              <td>Authenticate with <code>ADMIN_PASSWORD</code> from <code>.env</code></td>
            </tr>
            <tr>
              <td><span class="method get">GET</span></td>
              <td><code>/</code></td>
              <td>Dashboard — list of machines, actions, results, transfers</td>
            </tr>
            <tr>
              <td><span class="method get">GET</span></td>
              <td><code>/api/poll</code></td>
              <td>AJAX endpoint — returns full machine state as JSON (polled every 5 s by the UI)</td>
            </tr>
            <tr>
              <td><span class="method post">POST</span></td>
              <td><code>/action/&lt;uuid&gt;</code></td>
              <td>Enqueue a command for a machine</td>
            </tr>
            <tr>
              <td><span class="method post">POST</span></td>
              <td><code>/stage/&lt;uuid&gt;</code></td>
              <td>Upload a file from the browser and stage it for delivery to the victim</td>
            </tr>
            <tr>
              <td><span class="method get">GET</span></td>
              <td><code>/download/&lt;uuid&gt;/&lt;id&gt;</code></td>
              <td>Download a file received from the victim</td>
            </tr>
            <tr>
              <td><span class="method post">POST</span></td>
              <td><code>/logs/&lt;uuid&gt;/clear</code></td>
              <td>Clear all actions and results for a machine</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h3 class="sub-title" style="margin-top:1.5em">Rootkit API</h3>
      <div class="route-table-wrap">
        <table class="route-table">
          <thead><tr><th>Method</th><th>Route</th><th>Description</th></tr></thead>
          <tbody>
            <tr>
              <td><span class="method get">GET</span></td>
              <td><code>/register</code></td>
              <td>Register a new machine — returns a fresh UUID as plain text</td>
            </tr>
            <tr>
              <td><span class="method get">GET</span></td>
              <td><code>/api/&lt;uuid&gt;/action</code></td>
              <td>Pop the oldest pending action — returns <code>verb:args</code> or <code>204</code></td>
            </tr>
            <tr>
              <td><span class="method post">POST</span></td>
              <td><code>/api/&lt;uuid&gt;/result</code></td>
              <td>Store command output — body: <code>command</code>, <code>exit_code</code>, <code>stdout</code>, <code>stderr</code></td>
            </tr>
            <tr>
              <td><span class="method post">POST</span></td>
              <td><code>/api/&lt;uuid&gt;/file/&lt;path_b64&gt;</code></td>
              <td>Receive a file from the victim (download action) — raw binary body</td>
            </tr>
            <tr>
              <td><span class="method get">GET</span></td>
              <td><code>/api/&lt;uuid&gt;/file/&lt;path_b64&gt;</code></td>
              <td>Serve a staged file to the victim (upload action) — returns raw binary</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- 4. Dashboard -->
    <section class="section">
      <h2 class="section-title">04 — Dashboard</h2>

      <div class="placeholder large">
        <div class="placeholder-icon">📸</div>
        <p><strong>Screenshot à ajouter :</strong> vue complète du dashboard avec une machine connectée, ses actions récentes, ses résultats et la section file transfers.</p>
      </div>

      <div class="feature-list">
        <div class="feature-item">
          <div class="feature-dot"></div>
          <div>
            <strong>Live machine status</strong>
            <p>Each machine shows a green/red dot updated every 5 seconds via AJAX. A machine is considered online if its <code>last_seen</code> timestamp is less than 15 seconds old.</p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-dot"></div>
          <div>
            <strong>Action modal</strong>
            <p>Click <strong>+ Action</strong> on any machine to open a modal with four action types: Execute Command, Download File, Upload File, Reverse Shell.</p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-dot"></div>
          <div>
            <strong>AJAX live polling</strong>
            <p>The dashboard polls <code>/api/poll</code> every 5 seconds and updates machine status, action history, results, and file transfers without a page reload.</p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-dot"></div>
          <div>
            <strong>File transfers panel</strong>
            <p>Shows all uploads (↑) and downloads (↓) with their size and timestamp. Downloads include a <em>save</em> link to fetch the file to your browser.</p>
          </div>
        </div>
      </div>

      <div class="placeholder">
        <div class="placeholder-icon">📸</div>
        <p><strong>Screenshot à ajouter :</strong> modal "+ Action" ouvert sur "Execute Command".</p>
      </div>
    </section>

    <!-- 5. Authentication -->
    <section class="section">
      <h2 class="section-title">05 — Authentication</h2>
      <p class="section-desc">
        The dashboard is protected by a password stored in <code>.env</code> — never hardcoded in the source.
        The rootkit API has no authentication (by design for this pedagogical project).
      </p>

      <div class="code-block">
        <div class="code-title">.env</div>
        <pre><code>SECRET_KEY=your-long-random-secret-key
ADMIN_PASSWORD=yourpassword</code></pre>
      </div>

      <p class="section-desc" style="margin-top:1em">
        Sessions are managed by Flask's signed cookie mechanism using <code>SECRET_KEY</code>.
        The <code>@login_required</code> decorator protects all operator routes — any unauthenticated
        request is redirected to <code>/login</code>.
      </p>

      <div class="placeholder">
        <div class="placeholder-icon">📸</div>
        <p><strong>Screenshot à ajouter :</strong> page de login du C2.</p>
      </div>
    </section>

    <!-- 6. Online detection -->
    <section class="section">
      <h2 class="section-title">06 — Online detection</h2>
      <p class="section-desc">
        There is no persistent TCP connection between the rootkit and the C2.
        Instead, the server infers connection status from the polling frequency.
      </p>

      <div class="info-box">
        <strong>How it works:</strong><br/>
        Every time the rootkit polls <code>GET /api/&lt;uuid&gt;/action</code>, the server updates the <code>last_seen</code>
        timestamp in the <code>machines</code> table. The dashboard considers a machine <strong>online</strong>
        if <code>last_seen</code> is less than <strong>15 seconds</strong> ago — i.e. at most 3 missed polls (5 s interval).
        If the rootkit is unloaded or the victim goes down, the machine turns red within 15 seconds.
      </div>
    </section>

    <div class="nav-bottom">
      <a href="/features" class="btn-back">← All features</a>
      <a href="/features/connection" class="btn-next">Connection & Polling →</a>
    </div>

  </main>
  <Footer />
</body>
</html>

<style>
.breadcrumb {
  font-family: 'Courier New', monospace;
  font-size: 0.8em;
  color: var(--muted);
  margin-bottom: 1.5em;
  padding-top: 2em;
}
.breadcrumb a { color: var(--accent); }

.page-header {
  padding-bottom: 2em;
  border-bottom: 1px solid var(--border);
  margin-bottom: 3em;
}

.badge {
  display: inline-block;
  font-family: 'Courier New', monospace;
  font-size: 0.75em;
  color: var(--accent);
  border: 1px solid var(--accent);
  padding: 3px 10px;
  border-radius: 3px;
  letter-spacing: 2px;
  margin-bottom: 1em;
  text-transform: uppercase;
}

h1 { font-size: 2.4em; margin-bottom: 0.3em; }
.subtitle { color: var(--muted); font-size: 1em; margin: 0 0 1em; max-width: 580px; }

.tech-pills { display: flex; flex-wrap: wrap; gap: 6px; }

.pill {
  font-family: 'Courier New', monospace;
  font-size: 0.75em;
  background: rgba(0,255,65,0.08);
  color: var(--accent);
  border: 1px solid rgba(0,255,65,0.2);
  padding: 3px 10px;
  border-radius: 3px;
}

/* Sections */
.section { margin-bottom: 4em; }

.section-title {
  font-family: 'Courier New', monospace;
  font-size: 0.9em;
  color: var(--accent);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 0.8em;
}

.sub-title {
  font-family: 'Courier New', monospace;
  font-size: 0.8em;
  color: var(--muted);
  letter-spacing: 1px;
  text-transform: uppercase;
  margin-bottom: 0.8em;
}

.section-desc {
  color: var(--muted);
  font-size: 0.95em;
  max-width: 660px;
  margin-bottom: 1.5em;
}

/* Two cols */
.two-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 1em; }

.col-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 1.3em;
}

.col-card h3 { font-size: 1em; margin-bottom: 0.5em; }
.col-card p  { font-size: 0.88em; color: var(--muted); margin: 0; }

/* DB schema */
.db-schema {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1em;
}

.table-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 1em 1.2em;
}

.table-name {
  font-family: 'Courier New', monospace;
  font-size: 0.9em;
  color: var(--yellow);
  font-weight: bold;
  margin-bottom: 0.3em;
}

.table-desc {
  font-size: 0.8em;
  color: var(--muted);
  margin-bottom: 0.8em;
}

.cols { display: flex; flex-direction: column; gap: 3px; }

.col {
  font-family: 'Courier New', monospace;
  font-size: 0.78em;
  color: var(--text);
  display: flex;
  justify-content: space-between;
  padding: 2px 0;
  border-bottom: 1px solid var(--border);
}

.col:last-child { border-bottom: none; }
.col span { color: var(--muted); }
.col.pk { color: var(--accent); }
.col.fk { color: #58a6ff; }

/* Routes table */
.route-table-wrap {
  overflow-x: auto;
  border-radius: 8px;
  border: 1px solid var(--border);
}

.route-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.88em;
}

.route-table th {
  background: var(--surface);
  color: var(--accent);
  font-family: 'Courier New', monospace;
  font-size: 0.78em;
  letter-spacing: 1px;
  text-transform: uppercase;
  padding: 0.6em 1em;
  border-bottom: 1px solid var(--border);
}

.route-table td {
  padding: 0.6em 1em;
  border-bottom: 1px solid var(--border);
  color: var(--muted);
  vertical-align: middle;
}

.route-table tr:last-child td { border-bottom: none; }
.route-table tr:hover td { background: var(--surface); }

.method {
  font-family: 'Courier New', monospace;
  font-size: 0.75em;
  font-weight: bold;
  padding: 2px 8px;
  border-radius: 3px;
  white-space: nowrap;
}

.method.get  { background: rgba(0,255,65,0.12);  color: #00ff41; }
.method.post { background: rgba(227,179,65,0.12); color: #e3b341; }

/* Feature list */
.feature-list {
  display: flex;
  flex-direction: column;
  gap: 1em;
  margin: 1.5em 0;
}

.feature-item {
  display: flex;
  gap: 1em;
  align-items: flex-start;
}

.feature-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--accent);
  flex-shrink: 0;
  margin-top: 6px;
}

.feature-item strong { display: block; font-size: 0.95em; margin-bottom: 0.2em; }
.feature-item p { font-size: 0.88em; color: var(--muted); margin: 0; }

/* Code block */
.code-block {
  border: 1px solid var(--border);
  border-radius: 8px;
  overflow: hidden;
}

.code-title {
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  padding: 0.4em 1em;
  font-family: 'Courier New', monospace;
  font-size: 0.78em;
  color: var(--muted);
}

.code-block pre {
  margin: 0;
  border-radius: 0;
  border: none;
  padding: 1em 1.2em;
}

/* Info box */
.info-box {
  background: rgba(0,255,65,0.04);
  border: 1px solid rgba(0,255,65,0.2);
  border-radius: 6px;
  padding: 1em 1.2em;
  font-size: 0.88em;
  color: var(--muted);
  line-height: 1.6;
}

.info-box strong { color: var(--text); }

/* Placeholder */
.placeholder {
  border: 2px dashed var(--border);
  border-radius: 8px;
  padding: 2em;
  text-align: center;
  color: var(--muted);
  font-size: 0.85em;
  margin: 1em 0;
}

.placeholder.large { padding: 3em; }
.placeholder-icon { font-size: 1.8em; margin-bottom: 0.5em; }
.placeholder p { margin: 0; }

/* Nav bottom */
.nav-bottom {
  display: flex;
  justify-content: space-between;
  padding-top: 2em;
  border-top: 1px solid var(--border);
  margin-top: 2em;
}

.btn-back, .btn-next {
  font-family: 'Courier New', monospace;
  font-size: 0.85em;
  color: var(--accent);
  padding: 0.5em 1em;
  border: 1px solid rgba(0,255,65,0.3);
  border-radius: 4px;
  transition: background 0.15s;
}

.btn-back:hover, .btn-next:hover {
  background: rgba(0,255,65,0.08);
  text-decoration: none;
}

@media (max-width: 640px) {
  .two-cols   { grid-template-columns: 1fr; }
  .db-schema  { grid-template-columns: 1fr; }
  .nav-bottom { flex-direction: column; gap: 0.8em; }
}
</style>
