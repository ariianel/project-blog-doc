---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
</head>
<body>
	<Header />
	<main>

		<!-- Hero -->
		<section class="hero">
			<div class="badge">SYS2 · EPITA 2026</div>
			<h1>Wild Linux Kernel<br/><span class="accent">Object Module</span></h1>
			<p class="tagline">
				A pedagogical Linux kernel rootkit paired with a web-based C2 server —
				built to understand how rootkits work at the kernel level.
			</p>
			<div class="terminal">
				<div class="terminal-bar">
					<span class="dot red"></span>
					<span class="dot yellow"></span>
					<span class="dot green"></span>
					<span class="terminal-title">victim@arch ~ </span>
				</div>
				<div class="terminal-body">
					<p><span class="prompt">root@victim ~#</span> insmod wlkom.ko c2_host=10.0.2.2</p>
					<p><span class="comment">[  0.000] c2: registered uuid=12012406-c73f-4132-bfb6-53797ecb57ca</span></p>
					<p><span class="comment">[  0.001] c2: hiding module from lsmod...</span></p>
					<p><span class="comment">[  0.002] c2: polling /api/12012406-.../action every 5s</span></p>
					<p><span class="prompt">root@victim ~#</span> lsmod | grep wlkom</p>
					<p><span class="comment"># no output — the module is hidden</span></p>
					<p><span class="prompt">root@victim ~#</span><span class="cursor">▋</span></p>
				</div>
			</div>
		</section>

		<!-- What is it -->
		<section class="section">
			<h2 class="section-title">// What is WLKOM</h2>
			<p class="section-desc">
				WLKOM is a Linux Kernel Module (LKM) acting as a rootkit.
				Once loaded on a victim machine, it silently connects to a command-and-control server
				and awaits instructions — all while hiding itself from the system.
			</p>
			<div class="cards">
				<a href="/features/c2-server" class="card">
					<div class="card-header">
						<span class="card-icon">⚔️</span>
						<h3>C2 Server</h3>
					</div>
					<p>
						A Flask web application running on the attacker's machine.
						Provides a real-time dashboard to manage victim machines,
						dispatch commands, and transfer files.
					</p>
					<div class="card-tags">
						<span class="tag">Python</span>
						<span class="tag">Flask</span>
						<span class="tag">SQLite</span>
						<span class="tag">AJAX</span>
					</div>
				</a>
				<a href="/rootkit" class="card">
					<div class="card-header">
						<span class="card-icon">👻</span>
						<h3>Rootkit (LKM)</h3>
					</div>
					<p>
						A Linux Kernel Module loaded on the victim machine.
						Polls the C2 every 5 seconds, executes commands in kernel space,
						transfers files, and hides itself from userland tools.
					</p>
					<div class="card-tags">
						<span class="tag">C</span>
						<span class="tag">Linux Kernel</span>
						<span class="tag">HTTP/1.0</span>
						<span class="tag">Syscall hooks</span>
					</div>
				</a>
			</div>
		</section>

		<!-- Team -->
		<section class="section">
			<h2 class="section-title">// Team</h2>
			<div class="team">
				<div class="member">
					<img class="member-avatar" src="/ariane.png" alt="Ariane Luc" />
					<div>
						<div class="member-name">Ariane Luc</div>
						<div class="member-role">Upload/Download · AJAX polling · Doxygen</div>
					</div>
				</div>
				<div class="member">
					<img class="member-avatar" src="/daniel.png" alt="Daniel Janson" />
					<div>
						<div class="member-name">Daniel Janson</div>
						<div class="member-role">Architecture · C2 server · VM setup · Connection</div>
					</div>
				</div>
				<div class="member">
					<img class="member-avatar" src="/kealan.png" alt="Kealan Murphy Molas" />
					<div>
						<div class="member-name">Kealan Murphy Molas</div>
						<div class="member-role">Command execution · Hide files · Hide lines</div>
					</div>
				</div>
				<div class="member">
					<img class="member-avatar" src="/tom.png" alt="Tom Rioult Denorme" />
					<div>
						<div class="member-name">Tom Rioult Denorme</div>
						<div class="member-role">Persistence</div>
					</div>
				</div>
			</div>
		</section>

	</main>
	<Footer />
</body>
</html>

<style>
/* ── Hero ── */
.hero {
	padding: 4em 0 3em;
	border-bottom: 1px solid var(--border);
	margin-bottom: 3em;
}

.badge {
	display: inline-block;
	font-family: 'Courier New', monospace;
	font-size: 0.75em;
	color: var(--accent);
	border: 1px solid var(--accent);
	padding: 3px 10px;
	border-radius: 3px;
	letter-spacing: 2px;
	margin-bottom: 1.2em;
	text-transform: uppercase;
}

.hero h1 {
	font-size: 3em;
	line-height: 1.1;
	margin-bottom: 0.5em;
}

.accent { color: var(--accent); }

.tagline {
	color: var(--muted);
	font-size: 1.05em;
	max-width: 580px;
	margin-bottom: 2em;
}

/* ── Terminal ── */
.terminal {
	background: #010409;
	border: 1px solid var(--border);
	border-radius: 8px;
	overflow: hidden;
	max-width: 640px;
	font-family: 'Courier New', monospace;
	font-size: 0.85em;
}

.terminal-bar {
	background: var(--surface);
	padding: 8px 14px;
	display: flex;
	align-items: center;
	gap: 6px;
	border-bottom: 1px solid var(--border);
}

.dot {
	width: 12px; height: 12px;
	border-radius: 50%;
}
.dot.red    { background: #ff5f57; }
.dot.yellow { background: #ffbd2e; }
.dot.green  { background: #28c840; }

.terminal-title {
	margin-left: 8px;
	color: var(--muted);
	font-size: 0.9em;
}

.terminal-body {
	padding: 1.2em 1.4em;
	line-height: 1.8;
}

.terminal-body p { margin: 0; }

.prompt { color: var(--accent); }
.comment { color: #3a5a4a; }

.cursor {
	animation: blink 1s step-end infinite;
	color: var(--accent);
}

@keyframes blink { 50% { opacity: 0; } }

/* ── Sections ── */
.section {
	margin-bottom: 4em;
}

.section-title {
	font-family: 'Courier New', monospace;
	font-size: 1em;
	color: var(--accent);
	letter-spacing: 2px;
	text-transform: uppercase;
	margin-bottom: 0.8em;
}

.section-desc {
	color: var(--muted);
	max-width: 620px;
	margin-bottom: 2em;
}

/* ── Cards ── */
.cards {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 1em;
}

.card {
	background: var(--surface);
	border: 1px solid var(--border);
	border-radius: 8px;
	padding: 1.5em;
	transition: border-color 0.2s, transform 0.15s;
	display: block;
	text-decoration: none;
	color: inherit;
	cursor: pointer;
}

.card:hover { transform: translateY(-2px); }

.card:hover { border-color: var(--accent); }

.card-header {
	display: flex;
	align-items: center;
	gap: 0.6em;
	margin-bottom: 0.8em;
}

.card-icon { font-size: 1.3em; }

.card h3 {
	font-size: 1em;
	margin: 0;
	color: var(--text);
}

.card p {
	color: var(--muted);
	font-size: 0.9em;
	margin-bottom: 1em;
}

.card-tags {
	display: flex;
	flex-wrap: wrap;
	gap: 6px;
}

.tag {
	font-family: 'Courier New', monospace;
	font-size: 0.7em;
	background: rgba(0, 255, 65, 0.08);
	color: var(--accent);
	border: 1px solid rgba(0, 255, 65, 0.2);
	padding: 2px 8px;
	border-radius: 3px;
}

/* ── Features ── */
.features {
	display: flex;
	flex-direction: column;
	gap: 0;
	border: 1px solid var(--border);
	border-radius: 8px;
	overflow: hidden;
}

.feature {
	display: flex;
	align-items: flex-start;
	gap: 1em;
	padding: 1em 1.2em;
	border-bottom: 1px solid var(--border);
	transition: background 0.15s;
}

.feature:last-child { border-bottom: none; }
.feature:hover { background: var(--surface); }

.feature strong {
	display: block;
	font-size: 0.95em;
	margin-bottom: 0.2em;
	color: var(--text);
}

.feature p {
	margin: 0;
	font-size: 0.85em;
	color: var(--muted);
}

.status {
	flex-shrink: 0;
	width: 24px;
	height: 24px;
	display: flex;
	align-items: center;
	justify-content: center;
	font-size: 0.85em;
	color: var(--accent);
	margin-top: 2px;
}

.status.wip { color: var(--yellow); }

/* ── Team ── */
.team {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 1em;
}

.member {
	display: flex;
	align-items: center;
	gap: 1em;
	background: var(--surface);
	border: 1px solid var(--border);
	border-radius: 8px;
	padding: 1em 1.2em;
	transition: border-color 0.2s;
}

.member:hover { border-color: var(--accent); }

.member-avatar {
	width: 48px;
	height: 48px;
	border-radius: 50%;
	border: 2px solid rgba(0, 255, 65, 0.3);
	object-fit: cover;
	flex-shrink: 0;
}

.member-name {
	font-weight: 600;
	font-size: 0.95em;
	color: var(--text);
}

.member-role {
	font-size: 0.78em;
	color: var(--muted);
	margin-top: 2px;
}

@media (max-width: 640px) {
	.hero h1  { font-size: 2em; }
	.cards    { grid-template-columns: 1fr; }
	.team     { grid-template-columns: 1fr; }
}
</style>
