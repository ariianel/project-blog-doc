---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead title="Architecture — WLKOM" description="Technical architecture of the WLKOM rootkit and C2 server." />
</head>
<body>
	<Header />
	<main>

		<div class="page-header">
			<div class="badge">Technical deep-dive</div>
			<h1>// Architecture</h1>
			<p class="subtitle">How the C2 server and the rootkit are structured and communicate.</p>
		</div>

		<!-- 1. Global overview -->
		<section class="section">
			<h2 class="section-title">01 — Global overview</h2>
			<p class="section-desc">
				WLKOM is split into two components running on separate virtual machines hosted on the same physical laptop via QEMU/KVM.
				The victim VM loads the kernel module, which connects back to the C2 server and polls for instructions every 5 seconds.
			</p>

			<!-- SVG Architecture Diagram -->
			<div class="diagram-wrap">
				<svg viewBox="0 0 760 340" xmlns="http://www.w3.org/2000/svg" class="arch-svg">
					<!-- Host machine -->
					<rect x="10" y="10" width="740" height="320" rx="10" fill="#0d1117" stroke="#30363d" stroke-width="1.5"/>
					<text x="380" y="36" text-anchor="middle" fill="#8b949e" font-size="11" font-family="monospace" letter-spacing="2">HOST MACHINE — ARCH LINUX (SCHOOL LAPTOP)</text>

					<!-- QEMU label bottom -->
					<text x="380" y="318" text-anchor="middle" fill="#30363d" font-size="10" font-family="monospace" letter-spacing="2">QEMU / KVM HYPERVISOR</text>

					<!-- Attacker VM -->
					<rect x="40" y="55" width="300" height="235" rx="8" fill="#161b22" stroke="#30363d" stroke-width="1"/>
					<text x="190" y="78" text-anchor="middle" fill="#8b949e" font-size="10" font-family="monospace" letter-spacing="1">ATTACKER VM</text>

					<!-- Flask C2 box -->
					<rect x="65" y="90" width="250" height="80" rx="6" fill="#0d1117" stroke="#00ff41" stroke-width="1" stroke-opacity="0.4"/>
					<text x="190" y="112" text-anchor="middle" fill="#00ff41" font-size="12" font-family="monospace" font-weight="bold">Flask C2 Server</text>
					<text x="190" y="130" text-anchor="middle" fill="#8b949e" font-size="10" font-family="monospace">Python · SQLite · 0.0.0.0:5000</text>
					<text x="190" y="148" text-anchor="middle" fill="#8b949e" font-size="10" font-family="monospace">REST API + Web Dashboard</text>

					<!-- Web UI box -->
					<rect x="65" y="185" width="250" height="55" rx="6" fill="#0d1117" stroke="#30363d" stroke-width="1"/>
					<text x="190" y="208" text-anchor="middle" fill="#e6edf3" font-size="11" font-family="monospace">Web Dashboard</text>
					<text x="190" y="226" text-anchor="middle" fill="#8b949e" font-size="10" font-family="monospace">Jinja2 · AJAX polling · dark UI</text>

					<!-- Victim VM -->
					<rect x="420" y="55" width="300" height="235" rx="8" fill="#161b22" stroke="#30363d" stroke-width="1"/>
					<text x="570" y="78" text-anchor="middle" fill="#8b949e" font-size="10" font-family="monospace" letter-spacing="1">VICTIM VM</text>

					<!-- Kernel space box -->
					<rect x="445" y="90" width="250" height="140" rx="6" fill="#0d1117" stroke="#e3b341" stroke-width="1" stroke-opacity="0.4"/>
					<text x="570" y="112" text-anchor="middle" fill="#e3b341" font-size="11" font-family="monospace">Kernel Space</text>

					<!-- wlkom.ko -->
					<rect x="460" y="120" width="220" height="45" rx="4" fill="#161b22" stroke="#e3b341" stroke-width="1" stroke-opacity="0.6"/>
					<text x="570" y="138" text-anchor="middle" fill="#e3b341" font-size="12" font-family="monospace" font-weight="bold">wlkom.ko</text>
					<text x="570" y="155" text-anchor="middle" fill="#8b949e" font-size="10" font-family="monospace">Linux Kernel Module (LKM)</text>

					<!-- kthread -->
					<rect x="460" y="173" width="220" height="45" rx="4" fill="#161b22" stroke="#30363d" stroke-width="1"/>
					<text x="570" y="191" text-anchor="middle" fill="#e6edf3" font-size="11" font-family="monospace">c2_poll kthread</text>
					<text x="570" y="208" text-anchor="middle" fill="#8b949e" font-size="10" font-family="monospace">polls every 5 seconds</text>

					<!-- Arch Linux label -->
					<rect x="445" y="243" width="250" height="35" rx="4" fill="#0d1117" stroke="#30363d" stroke-width="1"/>
					<text x="570" y="262" text-anchor="middle" fill="#8b949e" font-size="10" font-family="monospace">Arch Linux · kernel ≥ 5.0</text>
					<text x="570" y="275" text-anchor="middle" fill="#30363d" font-size="9" font-family="monospace">SSH :10022 forwarded to host</text>

					<!-- HTTP arrow -->
					<defs>
						<marker id="arr" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
							<path d="M0,0 L0,6 L8,3 z" fill="#00ff41" opacity="0.8"/>
						</marker>
						<marker id="arr2" markerWidth="8" markerHeight="8" refX="2" refY="3" orient="auto">
							<path d="M8,0 L8,6 L0,3 z" fill="#00ff41" opacity="0.8"/>
						</marker>
					</defs>

					<!-- Double arrow -->
					<line x1="320" y1="155" x2="440" y2="155" stroke="#00ff41" stroke-width="1.5" stroke-opacity="0.6" marker-end="url(#arr)"/>
					<line x1="440" y1="167" x2="320" y2="167" stroke="#00ff41" stroke-width="1.5" stroke-opacity="0.6" marker-end="url(#arr2)"/>
					<rect x="340" y="142" width="80" height="38" rx="4" fill="#0d1117"/>
					<text x="380" y="158" text-anchor="middle" fill="#00ff41" font-size="10" font-family="monospace" font-weight="bold">HTTP/1.0</text>
					<text x="380" y="172" text-anchor="middle" fill="#8b949e" font-size="9" font-family="monospace">10.0.2.2:5000</text>
				</svg>
			</div>
		</section>

		<!-- 2. C2 API Protocol -->
		<section class="section">
			<h2 class="section-title">02 — C2 API Protocol</h2>
			<p class="section-desc">
				The rootkit communicates with the C2 server over plain HTTP/1.0 — a minimal custom HTTP client implemented entirely in kernel space.
			</p>

			<div class="api-table-wrap">
				<table class="api-table">
					<thead>
						<tr>
							<th>Method</th>
							<th>Route</th>
							<th>Direction</th>
							<th>Description</th>
						</tr>
					</thead>
					<tbody>
						<tr>
							<td><span class="method get">GET</span></td>
							<td><code>/register</code></td>
							<td>rootkit → C2</td>
							<td>Module registers on load. Server returns a UUID (plain text).</td>
						</tr>
						<tr>
							<td><span class="method get">GET</span></td>
							<td><code>/api/&lt;uuid&gt;/action</code></td>
							<td>rootkit → C2</td>
							<td>Polled every 5 s. Returns next pending action or <code>204</code> if none.</td>
						</tr>
						<tr>
							<td><span class="method post">POST</span></td>
							<td><code>/api/&lt;uuid&gt;/result</code></td>
							<td>rootkit → C2</td>
							<td>Posts command output back. Body fields: <code>exit_code</code>, <code>stdout</code>, <code>stderr</code>.</td>
						</tr>
						<tr>
							<td><span class="method post">POST</span></td>
							<td><code>/api/&lt;uuid&gt;/file/&lt;path_b64&gt;</code></td>
							<td>rootkit → C2</td>
							<td>Rootkit sends a file to the C2 (download action). Path encoded as URL-safe base64.</td>
						</tr>
						<tr>
							<td><span class="method get">GET</span></td>
							<td><code>/api/&lt;uuid&gt;/file/&lt;path_b64&gt;</code></td>
							<td>C2 → rootkit</td>
							<td>Rootkit fetches a staged file from the C2 (upload action).</td>
						</tr>
					</tbody>
				</table>
			</div>

			<!-- Sequence diagram -->
			<h3 class="sub-title">Communication flow</h3>
			<div class="seq">
				<div class="seq-col label-col"><span>Rootkit</span></div>
				<div class="seq-center">
					<div class="seq-line"></div>

					<div class="seq-step">
						<div class="seq-arrow right"><span class="arrow-label">GET /register</span></div>
						<div class="seq-arrow left"><span class="arrow-label response">200 — UUID</span></div>
					</div>

					<div class="seq-group">
						<div class="seq-group-label">every 5 seconds</div>
						<div class="seq-step">
							<div class="seq-arrow right"><span class="arrow-label">GET /api/&lt;uuid&gt;/action</span></div>
							<div class="seq-arrow left"><span class="arrow-label response">200 "exec:ls -la" &nbsp;or&nbsp; 204</span></div>
						</div>
					</div>

					<div class="seq-group case">
						<div class="seq-group-label case">case: exec</div>
						<div class="seq-step">
							<div class="seq-note">execute command → capture stdout/stderr</div>
							<div class="seq-arrow right"><span class="arrow-label">POST /api/&lt;uuid&gt;/result</span></div>
						</div>
					</div>

					<div class="seq-group case">
						<div class="seq-group-label case">case: download</div>
						<div class="seq-step">
							<div class="seq-note">read file from victim filesystem</div>
							<div class="seq-arrow right"><span class="arrow-label">POST /api/&lt;uuid&gt;/file/&lt;path_b64&gt; [body = file content]</span></div>
						</div>
					</div>

					<div class="seq-group case">
						<div class="seq-group-label case">case: upload</div>
						<div class="seq-step">
							<div class="seq-arrow right"><span class="arrow-label">GET /api/&lt;uuid&gt;/file/&lt;path_b64&gt;</span></div>
							<div class="seq-arrow left"><span class="arrow-label response">200 — file content</span></div>
							<div class="seq-note">write file to victim filesystem</div>
						</div>
					</div>

				</div>
				<div class="seq-col label-col"><span>C2 Server</span></div>
			</div>

			<div class="info-box">
				<strong>Why URL-safe base64 for the path?</strong><br/>
				File paths like <code>/etc/passwd</code> contain <code>/</code> which would break the URL routing.
				Standard base64 uses <code>+</code> and <code>/</code> which are reserved in URLs.
				URL-safe base64 replaces them with <code>-</code> and <code>_</code>, making the path safe to embed directly in a URL segment — without any additional encoding logic in kernel space.
			</div>
		</section>

		<!-- 3. Rootkit module structure -->
		<section class="section">
			<h2 class="section-title">03 — Kernel module structure</h2>
			<p class="section-desc">The rootkit is split into focused translation units, each responsible for one feature.</p>

			<div class="file-tree">
				<div class="tree-root">rootkit/src/</div>
				<div class="tree-file">
					<span class="tree-icon">📄</span>
					<code>wlkom_main.c</code>
					<span class="tree-desc">Module entry point — calls <code>hide_module()</code> then <code>c2_init()</code> on load</span>
				</div>
				<div class="tree-file">
					<span class="tree-icon">📄</span>
					<code>c2.c</code>
					<span class="tree-desc">HTTP/1.0 client — registration, action polling, result posting, file transfer</span>
				</div>
				<div class="tree-file">
					<span class="tree-icon">📄</span>
					<code>exec.c</code>
					<span class="tree-desc">Command execution via <code>call_usermodehelper()</code> and reverse shell</span>
				</div>
				<div class="tree-file">
					<span class="tree-icon">📄</span>
					<code>hide.c</code>
					<span class="tree-desc">Removes the module from <code>lsmod</code>, <code>/proc/modules</code>, and <code>/sys/module/</code></span>
				</div>
				<div class="tree-file">
					<span class="tree-icon">📄</span>
					<code>utils.c</code>
					<span class="tree-desc">Kernel VFS helpers — <code>read_file()</code> and <code>write_file()</code></span>
				</div>
			</div>

			<!-- Screenshot placeholder -->
			<div class="placeholder">
				<div class="placeholder-icon">📸</div>
				<p><strong>Screenshot à ajouter :</strong> sortie de <code>dmesg | tail -20</code> juste après le <code>insmod wlkom.ko</code> — montrant l'UUID de registration et le démarrage du kthread.</p>
			</div>
		</section>

		<!-- 4. Tech stack -->
		<section class="section">
			<h2 class="section-title">04 — Technology choices</h2>

			<div class="tech-grid">
				<div class="tech-card">
					<div class="tech-header">
						<span class="tech-lang">C</span>
						<h3>Kernel Module</h3>
					</div>
					<p>The Linux kernel only exposes a C API. There is no choice — kernel modules must be written in C (or assembly). No standard library, no malloc, no userspace — everything goes through kernel APIs (<code>kmalloc</code>, <code>printk</code>, <code>sock_create_kern</code>…).</p>
				</div>
				<div class="tech-card">
					<div class="tech-header">
						<span class="tech-lang">Python</span>
						<h3>C2 Server</h3>
					</div>
					<p>Flask allows rapid development of an HTTP API with a web frontend. SQLite via the standard <code>sqlite3</code> module gives us persistent storage without any extra setup. The entire server runs in a single process, which is ideal for this use case.</p>
				</div>
				<div class="tech-card">
					<div class="tech-header">
						<span class="tech-lang">QEMU</span>
						<h3>Virtualization</h3>
					</div>
					<p>Required by the subject. QEMU/KVM provides hardware virtualization on the school's Arch Linux laptops. The victim VM uses user-mode networking — the host is reachable from the VM at <code>10.0.2.2</code>, which is passed as the <code>c2_host</code> parameter at <code>insmod</code> time.</p>
				</div>
				<div class="tech-card">
					<div class="tech-header">
						<span class="tech-lang">Arch</span>
						<h3>Linux Distribution</h3>
					</div>
					<p>Arch Linux was chosen for both VMs because it matches the school laptops, ships with a recent kernel, and provides the <code>linux-headers</code> package needed to compile out-of-tree kernel modules against the running kernel version.</p>
				</div>
			</div>

			<div class="info-box">
				<strong>Why this specific kernel version?</strong><br/>
				Recent kernels (6.x+) enforce stricter security policies — in particular, lockdown mode and restricted <code>/proc/kallsyms</code> access make syscall hooking significantly harder without disabling specific kernel features. Our implementation targets kernel <strong>6.6 LTS</strong> (the default on current Arch), which still allows the syscall table manipulation used by the hide feature without requiring to disable Secure Boot or lockdown mode.
			</div>
		</section>

		<!-- 5. C2 dashboard screenshot placeholder -->
		<section class="section">
			<h2 class="section-title">05 — C2 Dashboard</h2>
			<p class="section-desc">The web interface provides real-time visibility over connected machines.</p>

			<div class="placeholder large">
				<div class="placeholder-icon">📸</div>
				<p><strong>Screenshot à ajouter :</strong> capture du dashboard C2 avec une machine connectée, des commandes exécutées et leur résultat, et la section file transfers.</p>
			</div>
		</section>

	</main>
	<Footer />
</body>
</html>

<style>
.page-header {
	padding: 3em 0 2em;
	border-bottom: 1px solid var(--border);
	margin-bottom: 3em;
}

.badge {
	display: inline-block;
	font-family: 'Courier New', monospace;
	font-size: 0.75em;
	color: var(--accent);
	border: 1px solid var(--accent);
	padding: 3px 10px;
	border-radius: 3px;
	letter-spacing: 2px;
	margin-bottom: 1em;
	text-transform: uppercase;
}

h1 {
	font-size: 2.4em;
	margin-bottom: 0.3em;
}

.subtitle {
	color: var(--muted);
	font-size: 1em;
	margin: 0;
}

/* ── Sections ── */
.section {
	margin-bottom: 4em;
}

.section-title {
	font-family: 'Courier New', monospace;
	font-size: 0.9em;
	color: var(--accent);
	letter-spacing: 2px;
	text-transform: uppercase;
	margin-bottom: 0.8em;
}

.section-desc {
	color: var(--muted);
	max-width: 660px;
	margin-bottom: 1.8em;
	font-size: 0.95em;
}

.sub-title {
	font-family: 'Courier New', monospace;
	font-size: 0.85em;
	color: var(--muted);
	letter-spacing: 1px;
	text-transform: uppercase;
	margin: 2em 0 1em;
}

/* ── SVG diagram ── */
.diagram-wrap {
	border: 1px solid var(--border);
	border-radius: 8px;
	overflow: hidden;
	background: #0d1117;
}

.arch-svg {
	width: 100%;
	height: auto;
	display: block;
}

/* ── API table ── */
.api-table-wrap {
	overflow-x: auto;
	border-radius: 8px;
	border: 1px solid var(--border);
}

.api-table {
	width: 100%;
	border-collapse: collapse;
	font-size: 0.88em;
}

.api-table th {
	background: var(--surface);
	color: var(--accent);
	font-family: 'Courier New', monospace;
	font-size: 0.8em;
	letter-spacing: 1px;
	text-transform: uppercase;
	padding: 0.7em 1em;
	border-bottom: 1px solid var(--border);
}

.api-table td {
	padding: 0.7em 1em;
	border-bottom: 1px solid var(--border);
	color: var(--text);
	vertical-align: top;
}

.api-table tr:last-child td { border-bottom: none; }
.api-table tr:hover td { background: var(--surface); }

.method {
	font-family: 'Courier New', monospace;
	font-size: 0.8em;
	font-weight: bold;
	padding: 2px 8px;
	border-radius: 3px;
}

.method.get  { background: rgba(0,255,65,0.12);  color: #00ff41; }
.method.post { background: rgba(227,179,65,0.12); color: #e3b341; }

/* ── Sequence diagram ── */
.seq {
	display: grid;
	grid-template-columns: 90px 1fr 90px;
	gap: 0;
	margin: 1em 0 1.5em;
	font-size: 0.85em;
}

.label-col {
	display: flex;
	align-items: flex-start;
	justify-content: center;
	padding-top: 0.5em;
}

.label-col span {
	font-family: 'Courier New', monospace;
	font-size: 0.8em;
	color: var(--accent);
	border: 1px solid var(--accent);
	padding: 4px 8px;
	border-radius: 4px;
	white-space: nowrap;
}

.seq-center {
	position: relative;
	padding: 0 1em;
	border-left: 1px dashed var(--border);
	border-right: 1px dashed var(--border);
}

.seq-step { margin-bottom: 0.5em; }

.seq-arrow {
	display: flex;
	align-items: center;
	padding: 4px 0;
}

.seq-arrow.right {
	justify-content: flex-end;
	border-bottom: 1px solid var(--accent);
	opacity: 0.8;
}

.seq-arrow.left {
	justify-content: flex-start;
	border-bottom: 1px solid rgba(0,255,65,0.3);
}

.arrow-label {
	font-family: 'Courier New', monospace;
	font-size: 0.82em;
	color: var(--text);
	padding: 0 6px;
}

.arrow-label.response { color: var(--muted); }

.seq-group {
	border: 1px solid var(--border);
	border-radius: 6px;
	padding: 0.5em 0.8em;
	margin: 0.6em 0;
}

.seq-group-label {
	font-family: 'Courier New', monospace;
	font-size: 0.72em;
	color: var(--muted);
	letter-spacing: 1px;
	text-transform: uppercase;
	margin-bottom: 0.5em;
}

.seq-group-label.case { color: var(--yellow); }

.seq-note {
	font-size: 0.78em;
	color: var(--muted);
	font-style: italic;
	padding: 2px 0;
}

/* ── Info box ── */
.info-box {
	background: rgba(0,255,65,0.04);
	border: 1px solid rgba(0,255,65,0.2);
	border-radius: 6px;
	padding: 1em 1.2em;
	font-size: 0.88em;
	color: var(--muted);
	margin-top: 1.5em;
	line-height: 1.6;
}

.info-box strong { color: var(--text); }

/* ── File tree ── */
.file-tree {
	background: var(--surface);
	border: 1px solid var(--border);
	border-radius: 8px;
	padding: 1.2em 1.5em;
	font-family: 'Courier New', monospace;
	font-size: 0.88em;
	margin-bottom: 1.5em;
}

.tree-root {
	color: var(--accent);
	font-weight: bold;
	margin-bottom: 0.6em;
}

.tree-file {
	display: flex;
	align-items: baseline;
	gap: 0.6em;
	padding: 0.3em 0;
	border-bottom: 1px solid var(--border);
}

.tree-file:last-child { border-bottom: none; }

.tree-file::before {
	content: '├─';
	color: var(--border);
}

.tree-icon { font-size: 0.9em; }

.tree-file code {
	color: var(--yellow);
	background: none;
	border: none;
	padding: 0;
	font-size: 1em;
	flex-shrink: 0;
}

.tree-desc {
	color: var(--muted);
	font-family: system-ui, sans-serif;
	font-size: 0.85em;
}

/* ── Tech grid ── */
.tech-grid {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 1em;
	margin-bottom: 1.5em;
}

.tech-card {
	background: var(--surface);
	border: 1px solid var(--border);
	border-radius: 8px;
	padding: 1.3em;
	transition: border-color 0.2s;
}

.tech-card:hover { border-color: var(--accent); }

.tech-header {
	display: flex;
	align-items: center;
	gap: 0.8em;
	margin-bottom: 0.7em;
}

.tech-lang {
	font-family: 'Courier New', monospace;
	font-size: 0.75em;
	font-weight: bold;
	background: rgba(0,255,65,0.08);
	color: var(--accent);
	border: 1px solid rgba(0,255,65,0.25);
	padding: 3px 8px;
	border-radius: 3px;
}

.tech-header h3 {
	margin: 0;
	font-size: 1em;
	color: var(--text);
}

.tech-card p {
	color: var(--muted);
	font-size: 0.88em;
	margin: 0;
	line-height: 1.6;
}

/* ── Placeholder ── */
.placeholder {
	border: 2px dashed var(--border);
